# ==============================================================================
# PROD ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env on your server and fill in the actual values.
# ==============================================================================

# --- GitHub Registry (For Pulling Images) ---
GITHUB_REPOSITORY_OWNER=

# --- Airflow Metadata Database (Postgres) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- ETL Dashboard Database (Postgres-ETL) ---
ETL_POSTGRES_USER=
ETL_POSTGRES_PASSWORD=
ETL_POSTGRES_DB=
ETL_POSTGRES_PORT=15432

# --- Web Application (Next.js) ---
# Format: postgresql://USER:PASSWORD@postgres-etl:5432/DB_NAME
DATABASE_URL=
JWT_SECRET=

# --- Airflow Configuration ---
AIRFLOW_UID=
AIRFLOW_WEB_PORT=8080
AIRFLOW__WEBSERVER__BASE_URL=
AIRFLOW__CORE__FERNET_KEY=

# Airflow First User (Initial Setup)
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=
