# ==============================================================================
# PRODUCTION ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================
# คำแนะนำ: คัดลอกไฟล์นี้เป็น .env บน Server และกรอกข้อมูลจริง
# รหัสผ่านควรมีความยาว 32 ตัวอักษรขึ้นไป และประกอบด้วยตัวเลขและอักขระพิเศษ

# --- GitHub Registry ---
# ชื่อเจ้าของ Repository (เช่น champ-tc)
GITHUB_REPOSITORY_OWNER=champ-tc

# --- Airflow Metadata Database (Postgres) ---
# แนะนำให้สุ่มชื่อ User และรหัสผ่านที่ซับซ้อน
POSTGRES_USER=airflow_admin_prod
POSTGRES_PASSWORD=
# ตัวอย่าง: pZ9#kM2vX8qR5nB1tW6y!JkL9mN2pQ5rS
POSTGRES_DB=airflow_metadata

# --- ETL Dashboard Database (Postgres-ETL) ---
# ฐานข้อมูลสำหรับเก็บข้อมูลผู้ป่วย (Production)
ETL_POSTGRES_USER=etl_manager_prod
ETL_POSTGRES_PASSWORD=
# ตัวอย่าง: hL4*jN7fT1sA9dC3xZ0w!mN2vP4rQ8sT
ETL_POSTGRES_DB=pm25_patients_db
ETL_POSTGRES_PORT=15432
# พอร์ตสำหรับต่อจากภายนอก (ถ้าต้องการ)

# --- Web Application (Next.js) ---
# DATABASE_URL จะดึงค่าจากตัวแปร ETL ด้านบน (ไม่ต้องแก้ไขตรงๆ)
DATABASE_URL=postgresql://${ETL_POSTGRES_USER}:${ETL_POSTGRES_PASSWORD}@postgres-etl:5432/${ETL_POSTGRES_DB}

# JWT Secret สำหรับระบบ Authentication (ควรสุ่ม 64 ตัวอักษร)
JWT_SECRET=
# ตัวอย่าง: 3f8e5c2b9a1d4f7e8c0b6a3d5e2f1g9h...

# Domain จริงของระบบ
NEXT_PUBLIC_API_URL=https://pm25-patients.ddc.moph.go.th

# --- Airflow Configuration ---
# AIRFLOW_UID: รันคำสั่ง 'id -u' บน Linux เพื่อดูค่า (ปกติคือ 1000 หรือ 501)
AIRFLOW_UID=1000

# Base URL สำหรับเข้าหน้า Airflow UI (Airflow 3 API server)
AIRFLOW__API__BASE_URL=https://pm25-patients.ddc.moph.go.th/airflow
AIRFLOW__API__SECRET_KEY=
# ใช้สำหรับ session/log auth ของ Airflow API server: สุ่มค่า 64 ตัวอักษรขึ้นไป
AIRFLOW__API_AUTH__JWT_SECRET=
# ใช้สำหรับ task execution token ของ Airflow 3: สุ่มค่า 64 ตัวอักษรขึ้นไป
AIRFLOW__FAB__COOKIE_SECURE=True
AIRFLOW__FAB__COOKIE_SAMESITE=Lax

# Fernet Key สำหรับเข้ารหัส Connection ใน Airflow (ต้องเป็น Base64 32-byte)
# วิธีสร้าง: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# ตัวอย่าง: vS0mN1lQ8Z7xW4vB3uT2aR1pG9oH6mK5iJ4nL3kM2jI=

# Airflow First User (Initial Setup)
# ใช้สำหรับ Login เข้าใช้งานครั้งแรก
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=
# ตัวอย่าง: Admin#PM25_2026!SecurePass321
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User
_AIRFLOW_WWW_USER_ROLE=Admin
