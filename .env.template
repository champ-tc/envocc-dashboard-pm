DATABASE_URL=postgresql://etl_user:ETL_POSTGRES_PASSWORD@postgres-etl:5432/etl_db
JWT_SECRET=                    # แนะนำ: 3f8e5c2b9a1d4f7e8c0b6a3d5e2f1g9h
NEXT_PUBLIC_API_URL=https://pm25-patients.ddc.moph.go.th

# --- Airflow Configuration ---
