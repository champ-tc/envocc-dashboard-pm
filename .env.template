# --- GitHub Registry ---
GITHUB_REPOSITORY_OWNER=your_github_username

# --- Airflow Metadata Database (Postgres) ---
POSTGRES_USER=airflow_system
POSTGRES_PASSWORD=             # แนะนำ: pZ9#kM2vX8qR5nB1tW6y
POSTGRES_DB=airflow

# --- ETL Dashboard Database (Postgres-ETL) ---
ETL_POSTGRES_USER=etl_user
ETL_POSTGRES_PASSWORD=         # แนะนำ: hL4*jN7fT1sA9dC3xZ0w
ETL_POSTGRES_DB=etl_db
ETL_POSTGRES_PORT=15432        # พอร์ตสำหรับต่อจากภายนอก

# --- Web Application (Next.js) ---
